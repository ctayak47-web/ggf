{
  "schemaVersion": 1,
  "id": "crolclient",
  "version": "${version}",
  "name": "CrolClient",
  "description": "Визуальный клиент для Minecraft: кастомизация HUD, тем оформления, косметических эффектов и честных утилит. Без чит-функций и PvP-ассистов.",
  "authors": [
    "CrolClient Team"
  ],
  "contact": {
    "homepage": "https://example.com/crolclient",
    "sources": "https://example.com/crolclient"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.crolclient.client.CrolClient"
    ]
  },
  "mixins": [
    "crolclient.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.10",
    "fabric-api": "*",
    "minecraft": "~1.21.4",
    "java": ">=21"
  }
}
